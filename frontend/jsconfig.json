{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "checkJs": true,
    "allowJs": true,
    "types": ["@timeless/types"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "include": [
    "src/**/*.js",
    "types/global.d.ts",
    "types/timeless.d.ts",
  ],
  "exclude": ["node_modules", "dist"]
}
