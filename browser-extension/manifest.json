{
  "manifest_version": 3,
  "name": "WX Channels Browser Extension",
  "version": "0.1.0",
  "description": "Injects content scripts on all websites and runs domain-specific collectors.",
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/common.js",
        "content/sites/zhihu.js",
        "content/dispatcher.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
