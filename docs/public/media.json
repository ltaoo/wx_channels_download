{
  "openapi": "3.0.0",
  "info": {
    "title": "WeChat Channels Download API - 媒体接口",
    "version": "v260330",
    "description": "媒体文件预览与播放接口"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:2022",
      "description": "本地服务器"
    }
  ],
  "tags": [
    {
      "name": "媒体",
      "description": "媒体文件预览与播放接口"
    }
  ],
  "paths": {
    "/file": {
      "get": {
        "tags": ["媒体"],
        "summary": "流媒体播放/下载",
        "description": "流式播放或下载已下载的媒体文件",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "文件相对路径（相对于下载目录）"
          },
          {
            "name": "download",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "是否强制下载 (1 为下载，否则流式播放)"
          }
        ],
        "responses": {
          "200": {
            "description": "媒体文件流"
          }
        }
      }
    },
    "/preview": {
      "get": {
        "tags": ["媒体"],
        "summary": "文件预览",
        "description": "预览已下载的文件，支持图片、视频等",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "文件相对路径"
          }
        ],
        "responses": {
          "200": {
            "description": "文件内容或预览页面"
          }
        }
      }
    }
  }
}