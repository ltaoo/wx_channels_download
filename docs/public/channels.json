{
  "openapi": "3.0.0",
  "info": {
    "title": "WeChat Channels Download API - 视频号接口",
    "version": "v260330",
    "description": "视频号相关接口"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:2022",
      "description": "本地服务器"
    }
  ],
  "tags": [
    {
      "name": "视频号",
      "description": "调用时保持视频号页面打开的状态，否则调用接口时会提示 `{\"code\":400,\"msg\":\"请先初始化客户端 socket 连接\"}`。当出现该提示时，打开视频号页面即可，如果已经打开，刷新一下。"
    }
  ],
  "paths": {
    "/api/channels/contact/search": {
      "get": {
        "tags": ["视频号"],
        "summary": "搜索视频号账号",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "搜索关键词"
          },
          {
            "name": "next_marker",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "分页标记，用于获取下一页数据"
          }
        ],
        "responses": {
          "200": {
            "description": "成功响应",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "msg": "成功",
                  "data": {
                    "errCode": 0,
                    "errMsg": "ok",
                    "data": {
                      "BaseResponse": { "Ret": 0, "ErrMsg": { "String": "" } },
                      "infoList": []
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/channels/contact/feed/list": {
      "get": {
        "tags": ["视频号"],
        "summary": "获取视频号指定账号的视频列表",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "视频号 ID，例如 `v2_xxx@finder`"
          },
          {
            "name": "next_marker",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "分页标记，用于获取下一页数据"
          }
        ],
        "responses": {
          "200": {
            "description": "成功响应",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "msg": "成功",
                  "data": {
                    "errCode": 0,
                    "errMsg": "ok",
                    "data": {
                      "object": []
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/channels/feed/profile": {
      "get": {
        "tags": ["视频号"],
        "summary": "获取视频号指定视频详情",
        "description": "**注意：必须提供 `oid`+`nid` 或 `url` 或 `eid` 其中一种组合。**",
        "parameters": [
          {
            "name": "oid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "视频唯一 ID (配合 nid 使用)"
          },
          {
            "name": "nid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "视频唯一 ID (配合 oid 使用)"
          },
          {
            "name": "url",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "视频号页面 URL"
          },
          {
            "name": "eid",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "企微打开视频号页面时 URL 会携带的参数"
          }
        ],
        "responses": {
          "200": {
            "description": "成功响应"
          }
        }
      }
    },
    "/api/channels/live/replay/list": {
      "get": {
        "tags": ["视频号"],
        "summary": "获取视频号直播回放列表",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "视频号 ID"
          },
          {
            "name": "next_marker",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "分页标记"
          }
        ],
        "responses": {
          "200": {
            "description": "成功响应"
          }
        }
      }
    },
    "/api/channels/interactioned/list": {
      "get": {
        "tags": ["视频号"],
        "summary": "获取我的赞和收藏列表",
        "parameters": [
          {
            "name": "next_marker",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "分页标记"
          },
          {
            "name": "flag",
            "in": "query",
            "required": false,
            "schema": { "type": "number", "enum": [1, 2, 4, 7] },
            "description": "赞、喜欢、收藏标记。1: 喜欢, 2: 赞, 4: 收藏, 7: 全部"
          }
        ],
        "responses": {
          "200": {
            "description": "成功响应"
          }
        }
      }
    },
    "/rss/channels": {
      "get": {
        "tags": ["视频号"],
        "summary": "RSS 订阅",
        "description": "获取指定视频号的 RSS Feed。",
        "parameters": [
          {
            "name": "username",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "视频号 ID"
          },
          {
            "name": "next_marker",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "分页标记"
          }
        ],
        "responses": {
          "200": {
            "description": "RSS XML"
          }
        }
      }
    },
    "/play": {
      "get": {
        "tags": ["视频号"],
        "summary": "视频代理播放",
        "description": "url 是视频地址，非「视频号页面地址」，同样需要对地址进行编码",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "目标视频地址"
          },
          {
            "name": "key",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "解密密钥"
          }
        ],
        "responses": {
          "200": {
            "description": "视频流"
          }
        }
      }
    }
  }
}