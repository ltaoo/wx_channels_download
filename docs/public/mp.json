{
  "openapi": "3.0.0",
  "info": {
    "title": "WeChat Channels Download API - 公众号接口",
    "version": "v260330",
    "description": "公众号相关接口"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:2022",
      "description": "本地服务器"
    }
  ],
  "tags": [
    {
      "name": "公众号",
      "description": "部分接口需要保持任意文章页面打开的状态，否则调用接口时会提示 `{\"code\":400,\"msg\":\"请先初始化客户端 socket 连接\"}`。当出现该提示时，打开任意公众号文章页面即可，如果已经打开，刷新一下。"
    }
  ],
  "paths": {
    "/api/mp/list": {
      "get": {
        "tags": ["公众号"],
        "summary": "获取公众号列表",
        "description": "**非微信公众号搜索接口**，获取的是本地已添加的公众号",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "鉴权 Token (开启鉴权时必填)"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "页码，默认 1"
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 10 },
            "description": "每页数量，默认 10"
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "搜索关键词 (匹配 biz 或 nickname)"
          },
          {
            "name": "is_effective",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "过滤是否有效 (1/true 为有效)"
          }
        ],
        "responses": {
          "200": {
            "description": "公众号列表"
          }
        }
      }
    },
    "/api/mp/msg/list": {
      "get": {
        "tags": ["公众号"],
        "summary": "获取公众号消息列表",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "鉴权 Token (开启鉴权时必填)"
          },
          {
            "name": "biz",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "公众号唯一 ID"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 0 },
            "description": "偏移量，默认 0"
          }
        ],
        "responses": {
          "200": {
            "description": "消息列表"
          }
        }
      }
    },
    "/api/mp/article/list": {
      "get": {
        "tags": ["公众号"],
        "summary": "获取公众号文章列表",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "鉴权 Token (开启鉴权时必填)"
          },
          {
            "name": "biz",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "公众号唯一 ID"
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 1 },
            "description": "页码，默认 1"
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 10 },
            "description": "每页数量，默认 10"
          }
        ],
        "responses": {
          "200": {
            "description": "文章列表"
          }
        }
      }
    },
    "/api/mp/delete": {
      "post": {
        "tags": ["公众号"],
        "summary": "删除公众号",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "鉴权 Token (开启鉴权时必填)"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "biz": {
                    "type": "string",
                    "description": "公众号唯一 ID"
                  }
                },
                "required": ["biz"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功"
          }
        }
      }
    },
    "/api/mp/refresh_with_frontend": {
      "post": {
        "tags": ["公众号"],
        "summary": "调用微信页面刷新凭证",
        "description": "借助已连接的前端（公众号文章页面）批量刷新公众号凭证。该接口会同步等待任务完成（或超时），但只返回操作结果状态，不返回详细的刷新数据。",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "biz_list": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "需要刷新的公众号 `biz` ID 列表。如果为空或不传，则刷新所有包含 `refresh_uri` 的公众号。"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功"
          }
        }
      }
    },
    "/api/mp/refresh": {
      "post": {
        "tags": ["公众号"],
        "summary": "更新凭证",
        "description": "更新指定公众号的凭证，需提交有效的凭证内容",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "刷新Token"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "biz": { "type": "string", "description": "公众号唯一 ID" },
                  "key": { "type": "string", "description": "授权 Key" },
                  "pass_ticket": { "type": "string", "description": "票据" },
                  "appmsg_token": { "type": "string", "description": "消息 Token" },
                  "uin": { "type": "string", "description": "用户唯一 ID" },
                  "nickname": { "type": "string", "description": "昵称" }
                },
                "required": ["biz", "key", "pass_ticket", "appmsg_token", "uin"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作成功"
          }
        }
      }
    },
    "/api/mp/ws_pool": {
      "get": {
        "tags": ["公众号"],
        "summary": "获取公众号 WebSocket 客户端池状态",
        "description": "获取当前连接的公众号前端 WebSocket 客户端信息",
        "responses": {
          "200": {
            "description": "客户端池状态",
            "content": {
              "application/json": {
                "example": {
                  "code": 0,
                  "msg": "成功",
                  "data": {
                    "clients": [],
                    "count": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "/rss/mp": {
      "get": {
        "tags": ["公众号"],
        "summary": "RSS 订阅",
        "description": "同样可以传入 `offset` 指定偏移量，获取到更多消息记录。\n\n还提供 `proxy` 和 `content` 参数，分别用于代理公众号内容和默认获取公众号文章全文",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "鉴权 Token (开启鉴权时必填)"
          },
          {
            "name": "biz",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "公众号唯一 ID"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "偏移量"
          },
          {
            "name": "content",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "是否获取正文 (1 为开启)。如果希望直接获取到正文，可以指定 `content=1`，那么请求 `RSS` 接口时，就会同时获取正文。但是缺点就是列表接口会比较慢（因为要依次请求到正文）"
          },
          {
            "name": "proxy",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "是否使用代理 (1 为开启)。仅在 `linux` 部署的服务上支持。如果阅读器提供获取全文能力，但是无法正确获取到公众号文章正文，可以指定 `proxy=1`，那么返回文章列表中，文章链接都会添加 `{{APIServerAddr}}/mp/proxy` 前缀，当打开文章时，将使用代理代为请求微信公众号返回正文内容"
          },
          {
            "name": "proxy_cover",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "enum": [0, 1] },
            "description": "是否只代理封面 (1 为开启)。仅在 `linux` 部署的服务上支持。相比 `proxy`，`proxy_cover` 仅代理封面图片，可以用在仅需查看列表，点击跳转到原文的场景"
          }
        ],
        "responses": {
          "200": {
            "description": "RSS XML"
          }
        }
      }
    },
    "/mp/proxy": {
      "get": {
        "tags": ["公众号"],
        "summary": "公众号内容代理",
        "description": "用于代理访问公众号文章或图片，解决跨域或防盗链问题。",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "目标 URL (需 URL 编码)"
          },
          {
            "name": "token",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "鉴权 Token (开启鉴权时必填)"
          }
        ],
        "responses": {
          "200": {
            "description": "代理的内容"
          }
        }
      }
    },
    "/mp/home": {
      "get": {
        "tags": ["公众号"],
        "summary": "公众号首页",
        "description": "返回公众号管理主页 HTML 页面",
        "responses": {
          "200": {
            "description": "HTML 页面"
          }
        }
      }
    }
  }
}