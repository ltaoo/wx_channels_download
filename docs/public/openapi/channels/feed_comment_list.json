    "summary": "获取视频评论列表",
    "description": "获取指定视频的评论列表",
    "parameters": [
      {
        "name": "oid",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "视频唯一 ID"
      },
      {
        "name": "nid",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "description": "视频 nid"
      },
      {
        "name": "next_marker",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "分页标记，用于获取下一页数据（使用响应的 lastBuffer 字段）"
      },
      {
        "name": "comment_id",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "default": ""
