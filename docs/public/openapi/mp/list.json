{
  "get": {
    "tags": [
      "公众号"
    ],
    "summary": "获取公众号列表",
    "description": "**非微信公众号搜索接口**，获取的是本地已添加的公众号",
    "parameters": [
      {
        "name": "token",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "鉴权 Token (开启鉴权时必填)"
      },
      {
        "name": "page",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 1
        },
        "description": "页码，默认 1"
      },
      {
        "name": "page_size",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 10
        },
        "description": "每页数量，默认 10"
      },
      {
        "name": "keyword",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        },
        "description": "搜索关键词 (匹配 biz 或 nickname)"
      },
      {
        "name": "is_effective",
        "in": "query",
        "required": false,
        "schema": {
          "type": "boolean"
        },
        "description": "过滤是否有效 (1/true 为有效)"
      }
    ],
    "responses": {
      "200": {
        "description": "公众号列表",
