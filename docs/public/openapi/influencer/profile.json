{
  "get": {
    "tags": [
      "达人"
    ],
    "summary": "获取达人详情（兼容 wx_channels_api）",
    "parameters": [
      {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      }
    ],
    "responses": {
      "200": {
        "description": "详情"
      }
    }
  },
  "put": {
    "tags": [
      "达人"
    ],
    "summary": "更新达人（兼容 wx_channels_api）",
