{
  "post": {
    "tags": [
      "下载器"
    ],
    "summary": "清空所有任务",
    "requestBody": {
      "required": false,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "delete_files": {
                "type": "boolean",
                "description": "是否同时删除已下载文件，默认 false"
              }
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "操作成功",
        "content": {
          "application/json": {
            "examples": {
              "success": {
                "summary": "成功",
                "value": {
                  "code": 0,
                  "msg": "成功",
                  "data": {}
                }
              },
              "fail": {
                "summary": "失败",
                "value": {
                  "code": 400,
                  "msg": "参数错误",
                  "data": {}
                }
              }
            }
          }
        }
      }
    }
  }
}
