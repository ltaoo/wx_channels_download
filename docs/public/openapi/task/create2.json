{
  "post": {
    "tags": [
      "下载器"
    ],
    "summary": "创建通用下载任务（公众号文章）",
    "description": "创建单个通用下载任务。用于下载公众号文章等任意直链 URL",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "下载地址，officialaccount://https://mp.weixin.qq.com/s/xxxxxxxxxxxxxxxxxxxxxx"
              },
              "filename": {
                "type": "string",
                "description": "文件名（包含扩展名）"
              },
              "dir": {
                "type": "string",
                "description": "保存目录（相对于下载目录，可为空）"
              },
              "extra": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "附加标签（可选）"
              }
            },
            "required": [
              "url"
            ]
          },
          "examples": {
            "mp_article": {
              "summary": "下载公众号文章",
              "value": {
                "url": "https://mp.weixin.qq.com/s/xxxxxxxxxxxxxxxxxxxxxx"
              }
            }
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "任务创建成功",
        "content": {
          "application/json": {
            "examples": {
              "success": {
                "summary": "成功",
                "value": {
                  "code": 0,
                  "msg": "成功",
                  "data": {
                    "id": "task_id"
                  }
                }
              },
              "dup": {
                "summary": "已存在",
                "value": {
                  "code": 409,
                  "msg": "已存在该下载内容"
                }
              },
              "fail": {
                "summary": "失败",
                "value": {
                  "code": 400,
                  "msg": "不合法的参数"
                }
              }
            }
          }
        }
      }
    }
  }
}
