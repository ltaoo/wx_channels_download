{
  "post": {
    "tags": [
      "下载器"
    ],
    "summary": "探测/解析下载链接",
    "description": "输入一个 URL，后端自动识别平台并解析出可下载的内容信息。也可用于继续已有的工作流。与 /api/task/probe 功能相同。",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "description": "要解析的内容 URL"
              },
              "run_id": {
                "type": "string",
                "description": "已有的工作流 run ID（用于继续）"
              },
              "probe_id": {
                "type": "string",
                "description": "run_id 的别名"
              },
              "extra": {
                "type": "object",
                "description": "平台特定的额外参数"
              }
            },
            "required": [
              "url"
            ]
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "解析结果",
        "content": {
          "application/json": {
            "examples": {
              "success": {
                "summary": "成功",
                "value": {
                  "code": 0,
                  "msg": "success",
                  "data": {
                    "run_id": "abc123",
                    "probe_id": "abc123",
                    "platform": "bilibili",
                    "content": {},
                    "probe": {},
                    "form": {},
                    "existing": []
                  }
                }
              },
              "missing_url": {
                "summary": "缺少 URL",
                "value": {
                  "code": 400,
                  "msg": "缺少 url 参数"
                }
              }
            }
          }
        }
      }
    }
  }
}
