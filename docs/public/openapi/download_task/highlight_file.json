{
  "post": {
    "tags": [
      "下载任务"
    ],
    "summary": "在文件管理器中高亮已下载文件（兼容 wx_channels_api）",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "file_path": {
                "type": "string",
                "description": "相对下载目录的文件路径"
              }
            },
            "required": [
              "file_path"
            ]
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "操作结果",
        "content": {
          "application/json": {
            "examples": {
              "success": {
                "summary": "成功",
                "value": {
                  "code": 0,
                  "msg": "成功",
                  "data": "Success"
                }
              }
            }
          }
        }
      }
    }
  }
}
