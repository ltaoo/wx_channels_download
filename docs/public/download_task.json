{
  "openapi": "3.0.0",
  "info": {
    "title": "WeChat Channels Download API - 下载任务接口",
    "version": "v260330",
    "description": "兼容 wx_channels_api 的下载任务接口"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:2022",
      "description": "本地服务器"
    }
  ],
  "tags": [
    {
      "name": "下载任务",
      "description": "兼容 wx_channels_api 的下载任务接口（/api/download_task/*），底层复用本项目的下载器与 download_task 表"
    }
  ],
  "paths": {
    "/api/download_task/list": {
      "post": {
        "tags": ["下载任务"],
        "summary": "获取下载任务列表（兼容 wx_channels_api）",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "page": { "type": "integer", "default": 1, "description": "页码（从 1 开始）" },
                  "pageSize": { "type": "integer", "default": 20, "description": "每页条数" },
                  "status": { "type": "integer", "description": "按 download_task.status 过滤" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "任务列表"
          }
        }
      }
    },
    "/api/download_task/start": {
      "post": {
        "tags": ["下载任务"],
        "summary": "开始/恢复下载任务（兼容 wx_channels_api）",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "download_task_id": { "type": "integer", "description": "download_task 表主键 id" } },
                "required": ["download_task_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作结果"
          }
        }
      }
    },
    "/api/download_task/profile": {
      "post": {
        "tags": ["下载任务"],
        "summary": "获取单个下载任务（兼容 wx_channels_api）",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "task_id": { "type": "string", "description": "下载器 task id（download_task.task_id）" } },
                "required": ["task_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "任务详情"
          }
        }
      }
    },
    "/api/download_task/create": {
      "post": {
        "tags": ["下载任务"],
        "summary": "创建视频号下载任务（兼容 wx_channels_api）",
        "description": "接收 ChannelsObject 结构的原始视频号数据，后端自动处理 format_feed（类似 format_feed 逻辑）、链接拼接、文件名生成、spec 处理等。支持 video、picture、live 三种类型。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "description": "内容 id（视频号 object id）" },
                  "contact": {
                    "type": "object",
                    "properties": {
                      "username": { "type": "string", "description": "视频号账号 username" },
                      "nickname": { "type": "string", "description": "视频号昵称" },
                      "headUrl": { "type": "string", "description": "视频号头像 URL" }
                    }
                  },
                  "objectDesc": {
                    "type": "object",
                    "properties": {
                      "description": { "type": "string", "description": "标题/描述" },
                      "mediaType": { "type": "integer", "description": "媒体类型（2=图片视频, 4=普通视频, 9=直播）" },
                      "media": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "url": { "type": "string", "description": "媒体 URL" },
                            "urlToken": { "type": "string", "description": "媒体 token" },
                            "coverUrl": { "type": "string", "description": "封面 URL" },
                            "decodeKey": { "type": "string", "description": "解密 key" },
                            "spec": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "fileFormat": { "type": "string", "description": "视频规格名称" }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  },
                  "objectNonceId": { "type": "string", "description": "nonce id" },
                  "source_url": { "type": "string", "description": "来源页面 URL（提供则直接使用）" },
                  "type": { "type": "string", "description": "feed 类型：media、picture、live" },
                  "liveInfo": { "type": "object", "description": "直播信息（live 类型时使用）" },
                  "files": { "type": "array", "description": "图片列表（picture 类型时使用）" },
                  "anchorContact": { "type": "object", "description": "主播信息（live 类型时使用）" }
                },
                "required": ["id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建结果"
          }
        }
      }
    },
    "/api/download_task/batch_create": {
      "post": {
        "tags": ["下载任务"],
        "summary": "批量创建下载任务（兼容 wx_channels_api）",
        "description": "批量接收 ChannelsObject 结构的原始视频号数据数组，后端自动处理 format_feed、链接拼接、文件名生成等。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "description": "内容 id" },
                    "contact": {
                      "type": "object",
                      "properties": {
                        "username": { "type": "string", "description": "视频号账号 username" },
                        "nickname": { "type": "string", "description": "视频号昵称" },
                        "headUrl": { "type": "string", "description": "视频号头像 URL" }
                      }
                    },
                    "objectDesc": {
                      "type": "object",
                      "properties": {
                        "description": { "type": "string", "description": "标题/描述" },
                        "mediaType": { "type": "integer", "description": "媒体类型" },
                        "media": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "url": { "type": "string", "description": "媒体 URL" },
                              "urlToken": { "type": "string", "description": "媒体 token" },
                              "coverUrl": { "type": "string", "description": "封面 URL" },
                              "decodeKey": { "type": "string", "description": "解密 key" }
                            }
                          }
                        }
                      }
                    },
                    "objectNonceId": { "type": "string", "description": "nonce id" },
                    "source_url": { "type": "string", "description": "来源页面 URL" }
                  },
                  "required": ["id"]
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建结果"
          }
        }
      }
    },
    "/api/download_task/delete": {
      "post": {
        "tags": ["下载任务"],
        "summary": "删除下载任务（兼容 wx_channels_api）",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "download_task_id": { "type": "integer", "description": "download_task 表主键 id" } },
                "required": ["download_task_id"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "删除结果"
          }
        }
      }
    },
    "/api/download_task/retry": {
      "post": {
        "tags": ["下载任务"],
        "summary": "重试下载任务（兼容 wx_channels_api）",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "id": { "type": "integer" } }, "required": ["id"] }
            }
          }
        },
        "responses": {
          "200": {
            "description": "重试结果"
          }
        }
      }
    },
    "/api/download_task/pause_all": {
      "post": {
        "tags": ["下载任务"],
        "summary": "暂停全部下载任务（兼容 wx_channels_api）",
        "responses": {
          "200": {
            "description": "操作结果"
          }
        }
      }
    },
    "/api/download_task/start_all": {
      "post": {
        "tags": ["下载任务"],
        "summary": "开始全部下载任务（兼容 wx_channels_api）",
        "responses": {
          "200": {
            "description": "操作结果"
          }
        }
      }
    },
    "/api/download_task/highlight_file": {
      "post": {
        "tags": ["下载任务"],
        "summary": "在文件管理器中高亮已下载文件（兼容 wx_channels_api）",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "file_path": { "type": "string", "description": "相对下载目录的文件路径" } }, "required": ["file_path"] }
            }
          }
        },
        "responses": {
          "200": {
            "description": "操作结果"
          }
        }
      }
    },
    "/api/download_task/play": {
      "get": {
        "tags": ["下载任务"],
        "summary": "在线播放已下载文件（兼容 wx_channels_api）",
        "parameters": [
          { "name": "id", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "download_task 表主键 id" }
        ],
        "responses": {
          "200": {
            "description": "文件流（或业务错误时返回 JSON）"
          }
        }
      }
    }
  }
}